#!/usr/bin/env bash
# render-image -- generate a single illustration on charlie via SDXL Turbo
# Usage: render-image "prompt text" output.png [--style silverstein|banksy|sketch]
#
# Renders in ~0.3s on RTX PRO 6000. Zero cost.

set -euo pipefail

CHARLIE="charlie"
PROMPT="${1:?Usage: render-image \"prompt\" output.png [--style name]}"
OUTPUT="${2:?Usage: render-image \"prompt\" output.png [--style name]}"
STYLE="silverstein"

shift 2
while [[ $# -gt 0 ]]; do
  case "$1" in
    --style) STYLE="$2"; shift 2 ;;
    *) shift ;;
  esac
done

# Style prefixes
declare -A STYLES
STYLES[silverstein]="black and white pen and ink illustration, simple clean line art, whimsical hand-drawn style like Shel Silverstein, minimal detail, white background,"
STYLES[banksy]="black and white stencil art, high contrast, bold shapes, street art aesthetic, spray paint texture, concrete wall background,"
STYLES[sketch]="rough pencil sketch on aged paper, architectural drawing style, hand-drawn lines with slight imperfection, margin notes,"
STYLES[terminal]="dark terminal screenshot, green on black, monospace font, hacker aesthetic,"
STYLES[diagram]="clean technical diagram, black lines on white, labeled components, arrows showing flow,"

PREFIX="${STYLES[$STYLE]:-${STYLES[silverstein]}}"
FULL_PROMPT="$PREFIX $PROMPT"

# Generate on charlie
REMOTE_OUT="/tmp/render-$$.png"
ssh "$CHARLIE" "PYTORCH_CUDA_ALLOC_CONF='backend:cudaMallocAsync' ~/venvs/ml/bin/python3 -c \"
import torch
torch.backends.cudnn.enabled = False
from diffusers import AutoPipelineForText2Image
pipe = AutoPipelineForText2Image.from_pretrained('stabilityai/sdxl-turbo', torch_dtype=torch.float16, variant='fp16')
pipe.vae.to(torch.float16)
pipe = pipe.to('cuda')
image = pipe('$FULL_PROMPT', num_inference_steps=1, guidance_scale=0.0, width=512, height=512).images[0]
image.save('$REMOTE_OUT')
print('done')
\" 2>/dev/null"

scp -q "$CHARLIE:$REMOTE_OUT" "$OUTPUT"
ssh "$CHARLIE" "rm -f $REMOTE_OUT"
echo "$OUTPUT"
